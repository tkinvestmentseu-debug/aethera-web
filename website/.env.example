# Website serverless functions — skopiuj do .env i uzupełnij
# NIGDY nie commituj .env do git

# Firebase API key — używany TYLKO przez serverless /api/reset-password
# Pobierz z: Firebase Console → Project Settings → Web API Key
FIREBASE_API_KEY=AIza-twoj-klucz-firebase

# Resend — wysyłanie emaili (formularz kontaktowy, signup)
# Rejestracja: https://resend.com → API Keys
RESEND_API_KEY=re_twoj_klucz_resend
