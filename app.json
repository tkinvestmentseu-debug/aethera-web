{
  "expo": {
    "name": "Aethera — Duchowy Asystent AI",
    "slug": "aethera",
    "version": "1.0.0",
    "description": "Aethera to premium aplikacja duchowego rozwoju z AI. Horoskopy, Tarot, Medytacje, Rytuały, Oracle AI i wspólnota duchowa.",
    "keywords": ["horoskop", "tarot", "medytacja", "astrologia", "rytuały", "oracle", "duchowość", "afirmacje", "numerologia", "aethera"],
    "primaryColor": "#7C3AED",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#07071A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aethera.app",
      "jsEngine": "hermes",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Aethera uses the camera for Vision Board and profile photo.",
        "NSPhotoLibraryUsageDescription": "Aethera accesses photos for Vision Board creation.",
        "NSMicrophoneUsageDescription": "Aethera uses the microphone for voice journal entries.",
        "NSUserNotificationUsageDescription": "Aethera sends daily spiritual reminders and ritual notifications.",
        "UIBackgroundModes": ["fetch", "remote-notification"]
      },
      "config": {
        "googleMobileAdsAppId": "ca-app-pub-PLACEHOLDER~PLACEHOLDER"
      },
      "buildNumber": "7"
    },
    "android": {
      "package": "com.aethera.app",
      "jsEngine": "hermes",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.NOTIFICATIONS",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "versionCode": 3
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "gradleVersion": "8.13"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Aethera używa biblioteki zdjęć tylko po to, by dodać osobisty portret do Twojego sanktuarium.",
          "cameraPermission": "Aethera może użyć aparatu, aby stworzyć osobisty portret dla Twojego sanktuarium."
        }
      ],
      "expo-font",
      "expo-audio",
      "@react-native-community/datetimepicker",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#010106",
          "sounds": []
        }
      ]
    ],
    "backgroundColor": "#010106",
    "scheme": "aethera",
    "assetBundlePatterns": [
      "assets/**/*"
    ],
    "extra": {
      "eas": {
        "projectId": "1d091bde-98e5-4ee4-89c1-f9cfc947f027"
      }
    }
  }
}