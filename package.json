{
  "name": "aethera",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo start",
    "start:tunnel": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo start --tunnel",
    "android": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo start --android",
    "ios": "cross-env NODE_OPTIONS=--max-old-space-size=8192 expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "i18n:build-memory": "node scripts/i18n/build-translation-memory.cjs",
    "i18n:audit": "node scripts/i18n/audit-i18n.cjs",
    "i18n:validate": "node scripts/i18n/validate-i18n.cjs",
    "i18n:translate-deepl": "node scripts/i18n/translate-deepl.cjs",
    "i18n:argos:install": "python scripts/i18n/install-argos-models.py",
    "i18n:master:catalog": "node scripts/i18n/build-master-catalog.cjs",
    "i18n:master:pl": "node scripts/i18n/generate-master-pl.cjs",
    "i18n:master:translate": "node scripts/i18n/translate-master.cjs",
    "i18n:master:validate": "node scripts/i18n/validate-master.cjs",
    "i18n:sync": "python -X utf8 scripts/i18n/i18n-sync.py",
    "i18n:sync:check": "python -X utf8 scripts/i18n/i18n-sync.py --check",
    "i18n:sync:dry": "python -X utf8 scripts/i18n/i18n-sync.py --dry-run"
  },
  "dependencies": {
    "@expo-google-fonts/cinzel": "^0.4.2",
    "@expo-google-fonts/raleway": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-native-community/slider": "^5.0.1",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@shopify/react-native-skia": "2.2.12",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-audio": "^1.1.1",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "^14.0.11",
    "expo-haptics": "^15.0.8",
    "expo-image-picker": "^17.0.10",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "^0.32.16",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "^6.0.9",
    "firebase": "10.14.1",
    "i18next": "^25.8.16",
    "lucide-react-native": "^0.577.0",
    "openai": "^6.27.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.6",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-pager-view": "^6.9.1",
    "react-native-reanimated": "~4.1.6",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-web": "0.21.0",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.3.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@expo/ngrok": "4.1.0",
    "@types/react": "~19.1.17",
    "cross-env": "^10.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-native": "0.81.5",
      "@types/react": "~19.1.17"
    }
  }
}
